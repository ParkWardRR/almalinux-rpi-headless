#cloud-config
#
# AlmaLinux Raspberry Pi — Verified Working user-data
#
# IMPORTANT: Modify the default "almalinux" user. Do NOT create custom users.
# Replace passwd hash and SSH key before deploying.
#

hostname: myhostname
ssh_pwauth: true

users:
  - name: almalinux
    groups: [ adm, systemd-journal ]
    sudo: [ "ALL=(ALL) NOPASSWD:ALL" ]
    lock_passwd: false
    # Generate your own: mkpasswd -m sha-512
    passwd: $6$rounds=4096$REPLACE_THIS$REPLACE_WITH_YOUR_OWN_HASH
    ssh_authorized_keys:
      - ssh-ed25519 AAAA_REPLACE_WITH_YOUR_PUBLIC_KEY user@hostname

chpasswd:
  expire: false
